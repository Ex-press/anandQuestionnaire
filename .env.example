# Copy to .env and fill in. Keep values UNQUOTED (this file is read by both
# python-dotenv and systemd EnvironmentFile, which does not strip quotes).

# Django
DJANGO_SECRET_KEY=change-me-run-the-generate-command-in-deploy-README
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=anand.artiswrong.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://anand.artiswrong.com

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=1024

# Screening: # of "yes" answers at/above which a completed screen is "positive".
SCREEN_POSITIVE_THRESHOLD=1

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
# Public base URL Twilio uses to reach the webhook (used for signature validation).
TWILIO_WEBHOOK_BASE_URL=https://anand.artiswrong.com
# Validate the X-Twilio-Signature header on inbound webhooks (recommended in prod).
TWILIO_VALIDATE_SIGNATURE=true
